# Copy this file to `.env` and fill in your keys:
#     cp .env.example .env
# agent.py and demo.py load it automatically. Real environment variables
# always override .env, so you can also do: OPENAI_MODEL=gpt-4.1 python agent.py ...

# ─── Which LLM backend agent.py uses by default ───────────────────────────────
# anthropic | openai   (override per-run with: agent.py --provider openai ...)
AGENT_PROVIDER=anthropic

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ─── OpenAI (and any OpenAI-compatible server) ────────────────────────────────
OPENAI_API_KEY=
# gpt-5 (reasoning, best for GUI) | gpt-5-mini | gpt-4o | gpt-4.1 | ...
OPENAI_MODEL=gpt-5
# GPT-5 / o-series are reasoning models: temperature is forced to 1.0 and a large
# token budget is used automatically. reasoning_effort: minimal | low | medium | high.
OPENAI_REASONING_EFFORT=low
# Point at a compatible server (Ollama, vLLM, LM Studio, Groq, OpenRouter, ...).
# Leave blank for api.openai.com. The model must support vision (image input).
# OPENAI_BASE_URL=http://localhost:11434/v1

# ─── VM connection (defaults already match win11.sh — usually leave as-is) ────
VM_SSH_HOST=127.0.0.1
VM_SSH_PORT=2222
VM_USER=user
VM_PASS=user
# Absolute path or relative-to-control/ path to the QMP socket. Auto-resolves
# to ../vms/win11-qmp.sock when blank.
# VM_QMP_SOCK=../vms/win11-qmp.sock
